---
const skillCategories = [
  {
    i18nKey: 'about.cat.backend',
    title: 'Backend & Lenguajes',
    skills: [
      { icon: '/icons/csharp.svg', name: 'C# / .NET' },
      { icon: '/icons/javascript.svg', name: 'JavaScript' },
      { icon: '/icons/typescript.svg', name: 'TypeScript' },
    ],
  },
  {
    i18nKey: 'about.cat.frontend',
    title: 'Frontend',
    skills: [
      { icon: '/icons/react.svg', name: 'React' },
      { icon: '/icons/nextjs.svg', name: 'Next.js' },
    ],
  },
  {
    i18nKey: 'about.cat.db',
    title: 'Bases de datos',
    skills: [
      { icon: '/icons/sqlserver.svg', name: 'SQL Server' },
      { icon: '/icons/mongodb.svg', name: 'MongoDB' },
    ],
  },
  {
    i18nKey: 'about.cat.devops',
    title: 'DevOps & Infra',
    skills: [
      { icon: '/icons/docker.svg', name: 'Docker' },
      { icon: '/icons/git.svg', name: 'Git / GitHub' },
      { icon: '/icons/github-actions.svg', name: 'GitHub Actions' },
      { icon: '/icons/nginx.svg', name: 'Nginx' },
      { icon: '/icons/linux.svg', name: 'Linux' },
      { icon: '/icons/azure.svg', name: 'Azure' },
    ],
  },
];
---

<section id="about" class="py-20 md:py-28 bg-surface dark:bg-dark-surface transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- About Text -->
      <div class="animate-on-scroll" data-animation="slide-right" data-delay="100">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary dark:text-dark-text-primary mb-3">
          <span data-i18n="about.title.1">Sobre </span><span class="gradient-text" data-i18n="about.title.2">Mí</span>
        </h2>
        <div class="section-divider mb-8"></div>

        <div class="space-y-4 text-text-secondary dark:text-dark-text-secondary text-base md:text-lg leading-relaxed">
          <p data-i18n-html="about.p1">
            <strong class="text-text-primary dark:text-dark-text-primary">Desarrollador Full Stack con más de 3 años de experiencia</strong> en diseño e implementación de sistemas web robustos y escalables.
          </p>
          <p data-i18n-html="about.p2">
            Especializado en arquitecturas backend con <strong class="text-primary dark:text-primary-light">.NET (C#)</strong>, APIs REST, interfaces con <strong class="text-primary dark:text-primary-light">React / Next.js</strong> y gestión de grandes volúmenes de datos en <strong class="text-primary dark:text-primary-light">SQL Server</strong> y <strong class="text-primary dark:text-primary-light">MongoDB</strong>.
          </p>
          <p data-i18n-html="about.p3">
            Experiencia en despliegue con Docker, CI/CD, balanceo de carga con Nginx y optimización de rendimiento en entornos empresariales de alto volumen.
          </p>
        </div>
      </div>

      <!-- Skills -->
      <div class="animate-on-scroll" data-animation="slide-left" data-delay="200">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-text-primary dark:text-dark-text-primary mb-3">
          <span class="gradient-text" data-i18n="about.skills">Tecnologías</span>
        </h2>
        <div class="section-divider mb-8"></div>

        <div class="space-y-8">
          {skillCategories.map((category) => (
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted dark:text-dark-text-muted mb-3" data-i18n={category.i18nKey}>
                {category.title}
              </h3>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {category.skills.map((skill) => (
                  <div class="group flex items-center gap-3 p-3 rounded-xl bg-surface-alt dark:bg-dark-surface-elevated border border-border dark:border-dark-border hover:border-primary/50 dark:hover:border-primary/50 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-0.5">
                    <img
                      src={skill.icon}
                      alt={skill.name}
                      class="w-8 h-8 object-contain group-hover:scale-110 transition-transform duration-300"
                      loading="lazy"
                    />
                    <span class="text-sm font-medium text-text-primary dark:text-dark-text-primary">
                      {skill.name}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
