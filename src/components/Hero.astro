---
const socialLinks = [
  { href: 'mailto:LuisVillarreal.lgvc@hotmail.com', icon: 'bi-envelope-fill', label: 'Email' },
  { href: 'https://github.com/LuisGVillarreal', icon: 'bi-github', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/luis-villarreal/', icon: 'bi-linkedin', label: 'LinkedIn' },
];
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/bg-cybvap.jpg"
      alt=""
      class="w-full h-full object-cover object-bottom blur-sm scale-105"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/70 to-primary-dark/50"></div>
    <!-- Animated gradient overlay -->
    <div class="absolute inset-0 opacity-30 bg-gradient-to-r from-primary/20 via-transparent to-accent/20" style="background-size: 200% 200%; animation: gradient-shift 8s ease infinite;"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full pt-24 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div class="text-center lg:text-left">
        <p
          class="animate-on-scroll text-lg md:text-xl text-white/80 font-medium mb-2"
          data-animation="fade-in"
          data-delay="200"
          data-i18n="hero.greeting"
        >
          ¡Hola! 👋
        </p>
        <h1
          class="animate-on-scroll text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-tight mb-4"
          data-animation="slide-up"
          data-delay="400"
        >
          <span data-i18n="hero.intro">Soy </span><span class="gradient-text">Luis Villarreal</span>
        </h1>
        <p
          class="animate-on-scroll text-xl md:text-2xl text-white/70 font-light mb-8"
          data-animation="slide-up"
          data-delay="600"
          data-i18n="hero.role"
        >
          Desarrollador Full Stack
        </p>

        <!-- Social Links -->
        <div
          class="animate-on-scroll flex items-center justify-center lg:justify-start gap-4"
          data-animation="slide-up"
          data-delay="800"
        >
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="group flex items-center justify-center w-12 h-12 rounded-xl bg-white/10 border border-white/20 text-white hover:bg-primary hover:border-primary hover:scale-110 transition-all duration-300"
            >
              <i class={`bi ${link.icon} text-xl`}></i>
            </a>
          ))}
        </div>
      </div>

      <!-- Profile Image -->
      <div class="flex justify-center lg:justify-end">
        <div
          class="animate-on-scroll relative"
          data-animation="scale-in"
          data-delay="600"
        >
          <!-- Glow ring -->
          <div class="absolute -inset-4 bg-gradient-to-r from-primary to-accent rounded-[2rem] opacity-20 blur-xl animate-glow"></div>
          <!-- Image container -->
          <div class="relative bg-white/10 backdrop-blur-sm border border-white/20 rounded-[2rem] p-8 animate-float">
            <img
              src="/images/profile.svg"
              alt="Luis Villarreal"
              class="w-64 h-64 md:w-80 md:h-80 object-contain"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <a href="#about" aria-label="Scroll down" class="text-white/50 hover:text-white transition-colors">
      <i class="bi bi-chevron-double-down text-2xl"></i>
    </a>
  </div>
</section>
