---
const contacts = [
  {
    href: 'mailto:LuisVillarreal.lgvc@hotmail.com',
    icon: 'bi-envelope-fill',
    label: 'LuisVillarreal.lgvc@hotmail.com',
    color: 'from-primary to-primary-dark',
  },
  {
    href: 'https://www.linkedin.com/in/luis-villarreal/',
    icon: 'bi-linkedin',
    label: 'Luis Villarreal',
    color: 'from-[#0077b5] to-[#005885]',
  },
];
---

<section id="contact" class="py-20 md:py-28 bg-surface dark:bg-dark-surface transition-colors duration-300">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2
        class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-text-primary dark:text-dark-text-primary mb-3"
        data-animation="slide-up"
      >
        <span data-i18n="contact.title.1">Ponte en </span><span class="gradient-text" data-i18n="contact.title.2">Contacto</span>
      </h2>
      <div class="section-divider mx-auto mb-6"></div>
      <p class="animate-on-scroll text-text-secondary dark:text-dark-text-secondary text-lg" data-animation="fade-in" data-delay="200" data-i18n="contact.subtitle">
        ¡No dudes en escribirme, me encantaría saber de ti!
      </p>
    </div>

    <!-- Contact Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {contacts.map((contact, index) => (
        <a
          href={contact.href}
          target="_blank"
          rel="noopener noreferrer"
          class="animate-on-scroll group flex flex-col items-center gap-4 p-8 rounded-2xl bg-surface-alt dark:bg-dark-surface-elevated border border-border dark:border-dark-border hover:border-primary/50 dark:hover:border-primary/50 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-1"
          data-animation="scale-in"
          data-delay={String(index * 150)}
        >
          <div class={`flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br ${contact.color} text-white shadow-lg group-hover:scale-110 transition-transform duration-300`}>
            <i class={`bi ${contact.icon} text-2xl`}></i>
          </div>
          <span class="text-text-primary dark:text-dark-text-primary font-medium text-center break-all">
            {contact.label}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
