---
const projects = [
  {
    image: '/projects/project_1.png',
    title: 'Auto Parts Store',
    description:
      'Proyecto de refaccionaria construido con PHP usando arquitectura MVC. Permite a los usuarios buscar y comprar artículos, mientras los administradores gestionan inventario y pedidos.',
    i18nDesc: 'projects.desc1',
    github: 'https://github.com/LuisGVillarreal/Refaccionaria-MVC',
    demo: 'https://refaccionaria-autos.000webhostapp.com',
    demoType: 'link' as const,
    tech: [
      { icon: '/icons/bootstrap.svg', name: 'Bootstrap' },
      { icon: '/icons/mysql.svg', name: 'MySQL' },
      { icon: '/icons/php.svg', name: 'PHP' },
    ],
  },
  {
    image: '/projects/project_2.png',
    title: 'PhotogramLaravel',
    description:
      'Este proyecto simula una red social tipo Instagram usando el framework Laravel, con likes, comentarios, sistema CRUD y uso de una API de IA para generar tags en imágenes.',
    i18nDesc: 'projects.desc2',
    github: 'https://github.com/LuisGVillarreal/PhotogramLaravel',
    demo: null,
    demoType: 'video' as const,
    tech: [
      { icon: '/icons/bootstrap.svg', name: 'Bootstrap' },
      { icon: '/icons/mysql.svg', name: 'MySQL' },
      { icon: '/icons/laravel.svg', name: 'Laravel' },
    ],
  },
  {
    image: '/projects/project_3.png',
    title: 'Blog API REST',
    description:
      'API de blog para interactuar con un sistema de blog, permitiendo registro de usuarios, gestión de categorías, publicación y actualización de posts, y obtención de información detallada.',
    i18nDesc: 'projects.desc3',
    github: 'https://github.com/LuisGVillarreal/api-rest-laravel-blog',
    demo: 'https://documenter.getpostman.com/view/25432378/2s93zCY17t',
    demoType: 'link' as const,
    tech: [
      { icon: '/icons/mysql.svg', name: 'MySQL' },
      { icon: '/icons/laravel.svg', name: 'Laravel' },
    ],
  },
];
---

<section id="projects" class="py-20 md:py-28 bg-surface-alt dark:bg-dark-surface-alt transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2
        class="animate-on-scroll font-heading text-3xl md:text-4xl font-bold text-text-primary dark:text-dark-text-primary mb-3"
        data-animation="slide-up"
      >
        <span data-i18n="projects.title.1">Mis </span><span class="gradient-text" data-i18n="projects.title.2">Proyectos</span>
      </h2>
      <div class="section-divider mx-auto"></div>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {projects.map((project, index) => (
        <div
          class="animate-on-scroll group relative rounded-2xl overflow-hidden bg-surface dark:bg-dark-surface-elevated border border-border dark:border-dark-border shadow-lg hover:shadow-2xl hover:shadow-primary/10 transition-all duration-500 hover:-translate-y-1"
          data-animation="scale-in"
          data-delay={String(index * 150)}
        >
          <!-- Project Image -->
          <div class="relative overflow-hidden aspect-video">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />

            <!-- Hover Overlay -->
            <div class="absolute inset-0 bg-black/70 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center p-6">
              <p class="text-white text-sm md:text-base text-center leading-relaxed mb-6 max-w-md" data-i18n={project.i18nDesc}>
                {project.description}
              </p>

              <!-- Action Links -->
              <div class="flex items-center gap-4">
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="View source code"
                  class="flex items-center justify-center w-11 h-11 rounded-xl bg-white/20 border border-white/30 text-white hover:bg-primary hover:border-primary hover:scale-110 transition-all duration-300"
                >
                  <i class="bi bi-github text-lg"></i>
                </a>
                {project.demoType === 'video' ? (
                  <button
                    type="button"
                    data-open-video
                    aria-label="Watch demo video"
                    class="flex items-center justify-center w-11 h-11 rounded-xl bg-white/20 border border-white/30 text-white hover:bg-accent hover:border-accent hover:scale-110 transition-all duration-300"
                  >
                    <i class="bi bi-play-fill text-xl"></i>
                  </button>
                ) : project.demo ? (
                  <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="View live demo"
                    class="flex items-center justify-center w-11 h-11 rounded-xl bg-white/20 border border-white/30 text-white hover:bg-accent hover:border-accent hover:scale-110 transition-all duration-300"
                  >
                    <i class="bi bi-eye-fill text-lg"></i>
                  </a>
                ) : null}
              </div>
            </div>
          </div>

          <!-- Project Footer: Title + Tech -->
          <div class="p-5 flex items-center justify-between">
            <h3 class="font-heading font-semibold text-lg text-text-primary dark:text-dark-text-primary">
              {project.title}
            </h3>
            <div class="flex items-center gap-2">
              {project.tech.map((t) => (
                <img
                  src={t.icon}
                  alt={t.name}
                  title={t.name}
                  class="w-6 h-6 object-contain opacity-70 hover:opacity-100 hover:scale-110 transition-all duration-300"
                  loading="lazy"
                />
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Video Modal -->
<dialog
  id="video-modal"
  class="fixed inset-0 z-[100] w-full max-w-3xl rounded-2xl bg-dark-surface border border-dark-border shadow-2xl backdrop:bg-black/70 backdrop:backdrop-blur-sm p-0 m-auto"
>
  <div class="flex items-center justify-between p-4 border-b border-dark-border">
    <h3 class="font-heading font-semibold text-lg text-white" data-i18n="projects.modal">Demo de PhotogramLaravel</h3>
    <button
      id="close-video-modal"
      type="button"
      aria-label="Close modal"
      class="w-9 h-9 flex items-center justify-center rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition-all duration-200"
    >
      <i class="bi bi-x-lg"></i>
    </button>
  </div>
  <div class="p-4">
    <video
      id="video-player"
      class="w-full rounded-xl"
      playsinline
      controls
    >
      <source src="/projects/project_2.mp4" type="video/mp4" />
    </video>
  </div>
</dialog>

<script>
  const dialog = document.getElementById('video-modal') as HTMLDialogElement;
  const video = document.getElementById('video-player') as HTMLVideoElement;
  const closeBtn = document.getElementById('close-video-modal');

  // Open modal
  document.querySelectorAll('[data-open-video]').forEach((btn) => {
    btn.addEventListener('click', () => {
      dialog?.showModal();
    });
  });

  // Close modal
  closeBtn?.addEventListener('click', () => {
    video?.pause();
    dialog?.close();
  });

  // Close on backdrop click
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) {
      video?.pause();
      dialog.close();
    }
  });

  // Pause video when modal closes
  dialog?.addEventListener('close', () => {
    video?.pause();
  });
</script>
